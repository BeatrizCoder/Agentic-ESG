# Feature Flags
USE_LLM=false
ENABLE_MEMORY=false
ENABLE_CREWAI_KNOWLEDGE=false
ENABLE_PROMPT_TEMPLATES=true
ENABLE_MCP=false
ENABLE_EXTERNAL_APIS=false
ENABLE_MOCK_INTEGRATIONS=true
ENABLE_REDIS_CACHE=false

# Database Configuration
DATABASE_PROVIDER=sqlite
DATABASE_URL=sqlite:///src/aamad/data/tickets.db

# Redis Configuration
REDIS_URL=redis://localhost:6379

# External API Authentication (leave empty for mock mode)
EXTERNAL_API_KEY=
GITHUB_TOKEN=
WEATHER_API_KEY=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Integration Configuration
INTEGRATION_RETRY_COUNT=3
INTEGRATION_TIMEOUT_SECONDS=30
INTEGRATION_RATE_LIMIT_PER_MINUTE=60