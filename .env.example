# ══════════════════════════════════════════════════════════════════════════════
# Climate Sentinel - Environment Variables Template
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ══════════════════════════════════════════════════════════════════════════════

# ── API Keys (REQUIRED) ───────────────────────────────────────────────────────
# Get your Anthropic API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
# MongoDB connection string (Railway, MongoDB Atlas, or local)
# Example: mongodb+srv://username:password@cluster.mongodb.net/climate_sentinel
MONGO_URL=mongodb://localhost:27017/climate_sentinel

# ── Server Configuration ──────────────────────────────────────────────────────
# Port for the FastAPI server (default: 8001)
PORT=8001

# Environment: development | staging | production
ENVIRONMENT=development

# ── CORS Configuration ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (NO SPACES)
# Development (localhost):
ALLOWED_ORIGINS=http://localhost:8001,http://localhost:3000,http://127.0.0.1:5500

# Production (explicit domains - RECOMMENDED):
# ALLOWED_ORIGINS=https://climate-sentinel-production.up.railway.app

# Wildcard (NOT RECOMMENDED for production):
# ALLOWED_ORIGINS=*

# ── API Authentication (OPTIONAL) ─────────────────────────────────────────────
# Comma-separated API keys for authentication (if implementing API key auth)
# API_KEYS=key1,key2,key3

# ── Rate Limiting (OPTIONAL) ──────────────────────────────────────────────────
# Requests per hour for /api/analyze endpoint (default: 10)
# RATE_LIMIT_PER_HOUR=10

# ── Logging (OPTIONAL) ────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_LEVEL=INFO

# ── NASA POWER API (OPTIONAL) ─────────────────────────────────────────────────
# Default year range for climate data (can be overridden per request)
# NASA_DEFAULT_START_YEAR=2014
# NASA_DEFAULT_END_YEAR=2023

# ══════════════════════════════════════════════════════════════════════════════
# Quick Start:
# 1. Copy this file: cp .env.example .env
# 2. Get Anthropic API key: https://console.anthropic.com/
# 3. Set up MongoDB: https://railway.app/ or https://www.mongodb.com/atlas
# 4. Fill in ANTHROPIC_API_KEY and MONGO_URL above
# 5. Run: uvicorn src.cs.backend:app --reload --port 8001
# ══════════════════════════════════════════════════════════════════════════════
