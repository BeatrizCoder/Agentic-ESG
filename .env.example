# ── Climate Sentinel Environment Configuration ────────────────────────────────

# ── Required: API Keys ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Required: Database ────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017/climate-sentinel

# ── Optional: Server Configuration ────────────────────────────────────────────
PORT=8001

# ── Optional: CORS Configuration ──────────────────────────────────────────────
# Development (allow all origins - NOT recommended for production):
# ALLOWED_ORIGINS=*

# Production (explicit origins only):
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Default (if not set): localhost origins for development
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8001
