# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-key-here

# ── MongoDB (Railway injects MONGO_URL automatically) ─────────────────────────
MONGO_URL=mongodb://user:pass@host:27017/climate_sentinel

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000

# ── CORS (comma-separated) ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
